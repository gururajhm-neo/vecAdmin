# Backend API URL
REACT_APP_API_URL=http://localhost:8000/api/v1

# Enable offline demo mode (no DB needed)
# REACT_APP_MOCK_MODE=true

# Optional: org name shown above the app title in the navbar and login screen
# Leave blank (or unset) to show just the app title
# REACT_APP_ORGANIZATION_NAME=Acme Corp

# App title and description (shown in login screen and browser tab)
REACT_APP_APP_TITLE=VecAdmin
REACT_APP_APP_DESCRIPTION=Admin UI for vector databases

# Demo login credentials (used in the login hints)
REACT_APP_DEMO_USER_1_EMAIL=engineer1@example.com
REACT_APP_DEMO_USER_1_PASSWORD=admin123
REACT_APP_DEMO_USER_2_EMAIL=engineer2@example.com
REACT_APP_DEMO_USER_2_PASSWORD=admin123
