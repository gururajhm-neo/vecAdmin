WEAVIATE_URL=http://localhost:8080
JWT_SECRET=change-this-secret-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1

# API metadata
APP_NAME=Weaviate Admin API
APP_DESCRIPTION=API for the Weaviate Admin Dashboard
APP_VERSION=1.0.0

# Scope field configuration (maps to data partitioning field in Weaviate)
SCOPE_FIELD_NAME=project_id
SCOPE_FIELD_VALUE_TYPE=int

# Optional bootstrap users JSON
# AUTH_USERS_JSON=[{"email":"engineer1@example.com","password":"admin123","name":"Engineer 1","project_id":21}]

# Optional project metadata JSON
# PROJECT_METADATA_JSON={"21":{"name":"Main Project","org_id":null}}
