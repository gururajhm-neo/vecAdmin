# ─── Vector Database Provider ─────────────────────────────────────────────────
# Options: weaviate | qdrant | chroma | faiss
DB_PROVIDER=weaviate

# ── Weaviate ──────────────────────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080

# ── Qdrant ────────────────────────────────────────────────────────────────────
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=
# QDRANT_HTTPS=false

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
# CHROMA_TENANT=default_tenant
# CHROMA_DATABASE=default_database

# ── FAISS (local flat-file, no server required) ────────────────────────────────
# FAISS_INDEX_DIR=./faiss_data

# ── AI Assistant (optional) ──────────────────────────────────────────────────
# Choose one provider. Default is groq (free tier).
# Options: groq | openai | anthropic | ollama
AI_PROVIDER=groq

# ── Groq (default — free tier) ────────────────────────────────────────────────
# Get a free key at https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MAX_TOKENS=32768
# GROQ_MAX_REQUESTS=1000

# ── OpenAI ────────────────────────────────────────────────────────────────────
# pip install openai  →  https://platform.openai.com
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Anthropic ─────────────────────────────────────────────────────────────────
# pip install anthropic  →  https://console.anthropic.com
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── Ollama (local, no key, no internet required) ──────────────────────────────
# brew install ollama && ollama pull llama3 && ollama serve
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ─── Auth & API ───────────────────────────────────────────────────────────────
JWT_SECRET=change-this-secret-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1

# API metadata
APP_NAME=VecAdmin API
APP_DESCRIPTION=Multi-provider vector database admin API
APP_VERSION=2.0.0

# ── Data partition / scope field ──────────────────────────────────────────────
# Controls whether queries are filtered to a specific field value (e.g. project_id).
#
# Single-tenant / generic dataset (default): leave SCOPE_FIELD_NAME unset or set
# to a field that doesn't exist. The ProjectSelector will not appear in the UI
# and ALL objects in every class are shown — works for any Weaviate instance.
#
# Multi-tenant: set SCOPE_FIELD_NAME to the field that partitions your data,
# then give each user a project_id (or tenant_id etc.) in AUTH_USERS_JSON.
# The UI will show a Project Selector dropdown and filter all views to that value.
#
# Examples:
#   SCOPE_FIELD_NAME=project_id      (partition by integer project_id)
#   SCOPE_FIELD_NAME=tenant_id       (partition by string tenant)
#   SCOPE_FIELD_VALUE_TYPE=int       (int or string, default: int)
#
# Leave blank to use the default (project_id / int) with no active filter:
SCOPE_FIELD_NAME=project_id
SCOPE_FIELD_VALUE_TYPE=int

# ── Authentication users ───────────────────────────────────────────────────────
# JSON array of user accounts. If not set, two demo accounts are created:
#   engineer1@example.com / admin123  (project_id: null = all data)
#   engineer2@example.com / admin123  (project_id: null = all data)
#
# Set project_id to a number to restrict a user to their partition:
#   AUTH_USERS_JSON=[{"email":"alice@acme.com","password":"secret","name":"Alice","project_id":null}]
#
# Multi-tenant example (each user sees only their own data):
#   AUTH_USERS_JSON=[
#     {"email":"team-a@acme.com","password":"passA","name":"Team A","project_id":1},
#     {"email":"team-b@acme.com","password":"passB","name":"Team B","project_id":2}
#   ]
# AUTH_USERS_JSON=

# ── Project / scope display names (optional) ──────────────────────────────────
# Maps numeric scope IDs to human-readable names shown in the UI dropdown.
# Only needed when SCOPE_FIELD_NAME is active and you want friendly names.
# PROJECT_METADATA_JSON={"1":{"name":"Team A"},"2":{"name":"Team B"}}
# PROJECT_METADATA_JSON=
